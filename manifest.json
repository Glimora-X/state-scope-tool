{
  "manifest_version": 3,
  "name": "StateScope",
  "version": "0.1.0",
  "description": "单据状态 L2 shadow 透视工具（P0 console diff）",
  "icons": {},
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/injector.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "host_permissions": ["http://*/*", "https://*/*"]
}
