{
  "manifest_version": 3,
  "name": "StateScope",
  "version": "0.5.6",
  "description": "单据状态 L2 shadow 透视 Chrome 扩展（P1.5 场景回归 + Issues）",
  "icons": {},
  "devtools_page": "src/devtools/devtools.html",
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/injector.js", "allowlists/*.json"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "host_permissions": ["http://*/*", "https://*/*"]
}
